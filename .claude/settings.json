{
  "permissions": {
    "allow": [
      "Bash(git push origin main)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/credentials*)",
      "Read(**/*.pem)",
      "Read(~/.aws/**)",
      "Read(~/.ssh/**)",
      "Bash(cat .env*)",
      "Bash(env)",
      "Bash(printenv)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_FILE_PATH\" | grep -qE '\\.(ts|tsx)$'; then cd \"$CLAUDE_PROJECT_DIR\" && npx tsc --noEmit 2>&1 | head -20; fi"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block_dangerous.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    }
  },
  "enabledPlugins": {
    "codex@openai-codex": true
  },
  "additionalDirectories": [
    "/Users/jimmie/Claude/Mirror NYC HQ"
  ]
}