# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Local env config. VITE_ vars are inlined into the client bundle at build
# time (not secret), but keep .env out of git so per-machine values don't
# clobber each other. .env.example is the tracked template.
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Supabase CLI scratch state (contains linked project ref + JWT secret)
supabase/.temp/

# Agent skills: machine-specific symlinks regenerated by `npx skills add ...`.
# Canonical content lives in .agents/skills/ which IS tracked.
.claude/skills/
# Per-agent working copies of the repo (each spawned agent gets its own checkout)
.claude/worktrees/
# Claude Code per-user settings (don't share across the team)
.claude/settings.local.json

# Local audit captures and auth state
.audit/

# Secrets / credentials. Never commit these. `/*.json` is too broad (would
# block package.json etc.), so list specific patterns + a local-only stash.
.local/
secrets/
*.pem
*.key
*service-account*.json
*-sa-key*.json
*-credentials*.json
google-*-key.json
